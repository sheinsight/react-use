    "semver": "^7.7.4",
    "shiki": "^1.29.2"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@rspress/plugin-shiki": "1.43.0",
    "@rspress/shared": "1.43.0",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@unocss/postcss": "^0.61.9",
    "@unocss/reset": "^0.61.9",
    "esno": "^4.8.0",
    "gray-matter": "^4.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "rsbuild-plugin-google-analytics": "^1.0.5",
    "unocss": "^0.61.9",
    "zx": "^8.8.5"
